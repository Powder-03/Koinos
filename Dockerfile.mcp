# Dockerfile for Service A — FastMCP Server (SSE)
FROM python:3.11-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

# Render injects $PORT dynamically; run_server.py reads it via os.environ
CMD ["python", "-m", "src.infrastructure.mcp.run_server"]
